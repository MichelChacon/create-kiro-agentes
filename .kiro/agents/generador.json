{
  "name": "generador",
  "description": "Genera agentes Kiro personalizados para profesionales que trabajan en AWS. Entrevista al usuario, investiga sus repos, selecciona el modelo optimo, y crea un agente completo con wiki, steering, skills y documentacion.",
  "model": "claude-sonnet-4-5",
  "prompt": "file://.kiro/agents/generador-prompt.md",
  "allowedTools": [
    "read", "write", "shell", "grep", "glob", "code",
    "knowledge", "todo_list", "subagent",
    "@aws",
    "@aws-documentation"
  ],
  "mcpServers": {
    "aws": {
      "command": "uvx",
      "args": ["mcp-proxy-for-aws@1.6.2", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "timeout": 100000
    },
    "aws-documentation": {
      "command": "uvx",
      "args": ["awslabs.aws-documentation-mcp-server@latest"],
      "env": {"FASTMCP_LOG_LEVEL": "ERROR"}
    }
  },
  "hooks": {
    "userPromptSubmit": [
      {
        "command": ".kiro/hooks/git-context.ps1",
        "description": "Inject git status and recent commits into context"
      }
    ],
    "stop": [
      {
        "command": ".kiro/hooks/flywheel-log.ps1",
        "description": "Log turn summary for flywheel analysis"
      }
    ]
  },
  "resources": [
    "file://.kiro/steering/**/*.md",
    "file://perfiles/**/*.md",
    "skill://.kiro/skills/**/SKILL.md"
  ]
}
