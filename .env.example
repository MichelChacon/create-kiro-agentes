# ============================================
# kiro-agentes — Variables de entorno
# ============================================
# Copiar a $PROFILE de PowerShell como $env:VARIABLE = "valor"
# O exportar en .bashrc/.zshrc según tu shell.

# --- Exa (búsqueda web) ---
# Requerido por: generador + agentes generados
# Obtener en: https://exa.ai/
EXA_API_KEY=

# --- Jira (gestión de tickets) ---
# Requerido por: agentes generados (no el generador)
# El generador solo necesita Exa; los agentes generados usan Jira para skills como
# investigar-ticket, revisar-tablero, deploy-cert, etc.
JIRA_URL=https://tu-instancia.atlassian.net
JIRA_USERNAME=tu-email@empresa.com
JIRA_API_TOKEN=

# --- Notas ---
# - En PowerShell, agregar a $PROFILE:
#     $env:EXA_API_KEY = "exa-..."
#     $env:JIRA_URL = "https://..."
#     $env:JIRA_USERNAME = "..."
#     $env:JIRA_API_TOKEN = "..."
#
# - El generador (crear-agente) solo requiere EXA_API_KEY.
# - Los agentes generados requieren las 4 variables.
