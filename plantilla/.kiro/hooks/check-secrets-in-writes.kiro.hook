{
  "enabled": true,
  "name": "Detectar secretos en escritura",
  "description": "Intercepta escritura de archivos para detectar tokens, API keys o passwords ANTES de que lleguen al disco.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": ["write"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "REVISA el contenido a escribir. Busca patrones peligrosos: tokens (ATATT3x, Bearer eyJ, sk-, pk-, ghp_), AWS Keys (AKIA, ASIA), passwords en texto plano, connection strings con credenciales, API keys hardcodeadas.\n\nEXCEPCIONES: .kiro/steering/, placeholders (<TOKEN>, YOUR_KEY_HERE), variables de entorno, .gitignore.\n\nSi hay secreto real: alertar y sugerir usar variable de entorno o Secrets Manager.\nSi NO hay secretos: permitir la escritura sin comentar nada."
  }
}
